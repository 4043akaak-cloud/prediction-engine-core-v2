import { describe, it, expect } from "vitest";
import { SeasonalityPredictionEngine } from "./SeasonalityPredictionEngine";
import { PredictionHistory } from "../types";

describe("SeasonalityPredictionEngine", () => {
  const engine = new SeasonalityPredictionEngine();

  // Helper to create mock history
  const createHistory = (query: string): PredictionHistory => ({
    query,
    timestamp: new Date().toISOString(),
    source: "test",
  });

  describe("Basic Prediction", () => {
    it("should return a valid PredictionResult", () => {
      const history = createHistory("What will happen next week?");
      const result = engine.predict(history);

      expect(result.prediction).toBeDefined();
      expect(result.confidence).toBeGreaterThanOrEqual(0.5);
      expect(result.confidence).toBeLessThanOrEqual(0.95);
      expect(result.reason).toBeDefined();
      expect(result.predictionId).toBeDefined();
      expect(result.timestamp).toBeDefined();
    });

    it("should implement IPredictionEngine interface", () => {
      const history = createHistory("Test query");
      const result = engine.predict(history);

      expect(result).toHaveProperty("prediction");
      expect(result).toHaveProperty("confidence");
      expect(result).toHaveProperty("metadata");
      expect(result).toHaveProperty("reason");
      expect(result).toHaveProperty("predictionId");
      expect(result).toHaveProperty("timestamp");
    });
  });

  describe("Periodicity Detection", () => {
    it("should detect daily patterns", () => {
      const history = createHistory("What happens every day?");
      const result = engine.predict(history);

      expect(result.reason).toContain("daily");
      expect(result.confidence).toBeGreaterThan(0.5);
    });

    it("should detect weekly patterns", () => {
      const history = createHistory("What happens every week?");
      const result = engine.predict(history);

      expect(result.reason).toContain("weekly");
      expect(result.confidence).toBeGreaterThan(0.5);
    });

    it("should detect monthly patterns", () => {
      const history = createHistory("What happens every month?");
      const result = engine.predict(history);

      expect(result.reason).toContain("monthly");
      expect(result.confidence).toBeGreaterThan(0.5);
    });

    it("should detect yearly patterns", () => {
      const history = createHistory("What happens every year?");
      const result = engine.predict(history);

      expect(result.reason).toContain("yearly");
      expect(result.confidence).toBeGreaterThan(0.5);
    });

    it("should detect quarterly patterns", () => {
      const history = createHistory("What happens quarterly?");
      const result = engine.predict(history);

      expect(result.reason).toContain("quarterly");
      expect(result.confidence).toBeGreaterThan(0.5);
    });
  });

  describe("Seasonal Factor Detection", () => {
    it("should detect time-based factors", () => {
      const history = createHistory("What happens in the morning?");
      const result = engine.predict(history);

      expect(result.reason).toContain("morning");
      expect(result.confidence).toBeGreaterThan(0.5);
    });

    it("should detect weather factors", () => {
      const history = createHistory("What happens when it rains?");
      const result = engine.predict(history);

      expect(result.reason).toContain("weather");
      expect(result.confidence).toBeGreaterThan(0.5);
    });

    it("should detect business cycle factors", () => {
      const history = createHistory("What happens in Q1?");
      const result = engine.predict(history);

      expect(result.reason).toContain("business");
      expect(result.confidence).toBeGreaterThan(0.5);
    });

    it("should detect market cycle factors", () => {
      const history = createHistory("What happens in the stock market?");
      const result = engine.predict(history);

      expect(result.reason).toContain("market");
      expect(result.confidence).toBeGreaterThan(0.5);
    });
  });

  describe("Trend Analysis", () => {
    it("should detect upward trends", () => {
      const history = createHistory("Will this trend upward?");
      const result = engine.predict(history);

      expect(result.reason).toContain("upward");
      expect(result.confidence).toBeGreaterThan(0.5);
    });

    it("should detect downward trends", () => {
      const history = createHistory("Will this decline downward?");
      const result = engine.predict(history);

      expect(result.reason).toContain("downward");
      expect(result.confidence).toBeGreaterThan(0.5);
    });

    it("should detect stable trends", () => {
      const history = createHistory("Will this remain stable?");
      const result = engine.predict(history);

      expect(result.reason).toContain("stable");
      expect(result.confidence).toBeGreaterThan(0.5);
    });
  });

  describe("Confidence Calculation", () => {
    it("should have higher confidence for multiple periodic patterns", () => {
      const history = createHistory(
        "What happens every week on Monday in the morning?"
      );
      const result = engine.predict(history);

      expect(result.confidence).toBeGreaterThan(0.6);
    });

    it("should have baseline confidence for no patterns", () => {
      const history = createHistory("Random query");
      const result = engine.predict(history);

      expect(result.confidence).toBeGreaterThanOrEqual(0.5);
      expect(result.confidence).toBeLessThanOrEqual(0.95);
    });

    it("should cap confidence at 0.95", () => {
      const history = createHistory(
        "What happens every day weekly monthly yearly quarterly in the morning with seasonal effects?"
      );
      const result = engine.predict(history);

      expect(result.confidence).toBeLessThanOrEqual(0.95);
    });
  });

  describe("Metadata", () => {
    it("should include correct metadata", () => {
      const history = createHistory("Test query");
      const result = engine.predict(history);

      expect(result.metadata).toBeDefined();
      expect(result.metadata.recipeId).toBe("seasonality-recipe");
      expect(result.metadata.recipeName).toBe("Seasonality Analysis Recipe");
      expect(result.metadata.executionTimestamp).toBeDefined();
      expect(result.metadata.confidenceScore).toBe(result.confidence);
      expect(result.metadata.evidenceCount).toBeGreaterThanOrEqual(0);
      expect(result.metadata.predictionVersion).toBe("1.0.0");
    });
  });

  describe("Reason Generation", () => {
    it("should generate detailed reason", () => {
      const history = createHistory("What happens weekly in the morning?");
      const result = engine.predict(history);

      expect(result.reason).toContain("Detected");
      expect(result.reason).toContain("periodic");
      expect(result.reason).toContain("Evidence count");
    });

    it("should handle no patterns gracefully", () => {
      const history = createHistory("xyz abc");
      const result = engine.predict(history);

      expect(result.reason).toBeDefined();
      expect(result.reason.length).toBeGreaterThan(0);
    });
  });

  describe("Prediction ID", () => {
    it("should generate unique prediction IDs", () => {
      const history = createHistory("Test query");
      const result1 = engine.predict(history);
      const result2 = engine.predict(history);

      expect(result1.predictionId).not.toBe(result2.predictionId);
    });

    it("should follow UUID format", () => {
      const history = createHistory("Test query");
      const result = engine.predict(history);

      const uuidRegex =
        /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;
      expect(result.predictionId).toMatch(uuidRegex);
    });
  });

  describe("Timestamp", () => {
    it("should include ISO timestamp", () => {
      const history = createHistory("Test query");
      const result = engine.predict(history);

      expect(result.timestamp).toBeDefined();
      expect(() => new Date(result.timestamp)).not.toThrow();
    });
  });

  describe("Edge Cases", () => {
    it("should handle empty query", () => {
      const history = createHistory("");
      const result = engine.predict(history);

      expect(result.prediction).toBeDefined();
      expect(result.confidence).toBeGreaterThanOrEqual(0.5);
    });

    it("should handle very long query", () => {
      const longQuery = "test ".repeat(100);
      const history = createHistory(longQuery);
      const result = engine.predict(history);

      expect(result.prediction).toBeDefined();
      expect(result.confidence).toBeGreaterThanOrEqual(0.5);
    });

    it("should handle special characters", () => {
      const history = createHistory("What happens with @#$%^&*()?");
      const result = engine.predict(history);

      expect(result.prediction).toBeDefined();
      expect(result.confidence).toBeGreaterThanOrEqual(0.5);
    });

    it("should be case-insensitive", () => {
      const history1 = createHistory("WHAT HAPPENS WEEKLY?");
      const history2 = createHistory("what happens weekly?");

      const result1 = engine.predict(history1);
      const result2 = engine.predict(history2);

      expect(result1.reason).toContain("weekly");
      expect(result2.reason).toContain("weekly");
    });
  });

  describe("Multiple Seasonal Factors", () => {
    it("should detect multiple seasonal factors", () => {
      const history = createHistory(
        "What happens every morning during hot weather with quarterly earnings?"
      );
      const result = engine.predict(history);

      expect(result.reason).toContain("morning");
      expect(result.reason).toContain("heat");
      expect(result.reason).toContain("quarterly");
      expect(result.confidence).toBeGreaterThan(0.6);
    });
  });

  describe("Seasonality Strength", () => {
    it("should increase confidence with seasonal keywords", () => {
      const history = createHistory(
        "What happens with seasonality and seasonal patterns?"
      );
      const result = engine.predict(history);

      expect(result.confidence).toBeGreaterThan(0.5);
      expect(result.reason).toContain("Seasonal strength");
    });
  });
});
